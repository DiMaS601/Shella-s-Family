<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Keluarga Marchella - Family Tree</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            color: #333;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        header {
            text-align: center;
            background: rgba(255,255,255,0.95);
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            margin-bottom: 30px;
        }

        h1 {
            color: #4a5568;
            font-size: 2.5em;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
        }

        .subtitle {
            color: #718096;
            font-size: 1.2em;
        }

        .search-container {
            background: rgba(255,255,255,0.95);
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
            margin-bottom: 30px;
        }

        .search-box {
            width: 100%;
            padding: 15px 20px;
            font-size: 1.1em;
            border: 2px solid #e2e8f0;
            border-radius: 50px;
            outline: none;
            transition: all 0.3s ease;
        }

        .search-box:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .family-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .family-card {
            background: rgba(255,255,255,0.95);
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
            transition: all 0.3s ease;
            border-left: 5px solid #667eea;
            opacity: 1;
        }

        .family-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.2);
        }

        .family-card.hidden {
            display: none;
        }

        .name {
            font-size: 1.5em;
            font-weight: bold;
            color: #2d3748;
            margin-bottom: 8px;
        }

        .role {
            background: linear-gradient(45deg, #667eea, #764ba2);
            color: white;
            padding: 8px 15px;
            border-radius: 25px;
            font-size: 0.9em;
            font-weight: 600;
            display: inline-block;
            margin-bottom: 10px;
        }

        .location {
            color: #718096;
            font-style: italic;
            margin-bottom: 10px;
        }

        .chatbot-container {
            background: rgba(255,255,255,0.95);
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
            margin-bottom: 30px;
        }

        .chatbot-header {
            background: linear-gradient(45deg, #48bb78, #38a169);
            color: white;
            padding: 15px;
            border-radius: 10px;
            text-align: center;
            margin-bottom: 20px;
            font-weight: bold;
        }

        #chatInput {
            width: 100%;
            padding: 15px;
            border: 2px solid #e2e8f0;
            border-radius: 25px;
            font-size: 1em;
            outline: none;
            margin-bottom: 15px;
        }

        #chatInput:focus {
            border-color: #48bb78;
        }

        #chatMessages {
            height: 300px;
            overflow-y: auto;
            background: #f7fafc;
            border-radius: 10px;
            padding: 15px;
            border: 1px solid #e2e8f0;
            margin-bottom: 15px;
        }

        .message {
            margin-bottom: 10px;
            padding: 10px;
            border-radius: 10px;
        }

        .user-message {
            background: #667eea;
            color: white;
            text-align: right;
        }

        .bot-message {
            background: white;
            border: 1px solid #e2e8f0;
            color: #2d3748;
        }

        .bonus {
            background: linear-gradient(45deg, #ff6b6b, #feca57);
            color: white;
            padding: 30px;
            border-radius: 20px;
            text-align: center;
            font-size: 1.5em;
            font-weight: bold;
            box-shadow: 0 15px 40px rgba(0,0,0,0.2);
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }

        @media (max-width: 768px) {
            .family-grid {
                grid-template-columns: 1fr;
            }
            
            h1 {
                font-size: 2em;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>🌳 Keluarga Marchella 🌳</h1>
            <p class="subtitle">Family Tree Lengkap - Marchella & Keluarga Besar</p>
        </header>

        <div class="search-container">
            <input type="text" class="search-box" id="searchInput" placeholder="🔍 Cari nama anggota keluarga...">
        </div>

        <div class="chatbot-container">
            <div class="chatbot-header">💬 Chatbot Keluarga Marchella</div>
            <div id="chatMessages">
                <div class="message bot-message">Halo! Saya chatbot keluarga Marchella. Ketik "halo" atau tanya tentang keluarga!</div>
            </div>
            <input type="text" id="chatInput" placeholder="Ketik pesan Anda di sini..." onkeypress="handleChat(event)">
        </div>

        <div class="family-grid" id="familyGrid">
            <!-- Family members akan di-generate oleh JavaScript -->
        </div>

        <div class="bonus">
            🎁 BONUS: Dia suka Haikal 🎁
        </div>
    </div>

    <script>
        const familyData = [
            {name: "Marchella", role: "Teman saya ❤️", location: ""},
            {name: "Halimah", role: "Bude", location: ""},
            {name: "Hari", role: "Mbah", location: "(Jatim)"},
            {name: "Harun", role: "Sepupu seumuran", location: "(Tanjung)"},
            {name: "Hanin", role: "Adek sepupu", location: ""},
            {name: "Hasan", role: "Mas/kakak sepupu", location: ""},
            {name: "Yarta", role: "Mas/kakak sepupu", location: "(Sumatra Utara)"},
            {name: "Yanti", role: "Mbah", location: "(Tanjung)"},
            {name: "Yanto", role: "*lu udah tau*", location: ""},
            {name: "Aprilia", role: "*lu udah tau*", location: ""},
            {name: "Anggi", role: "Adek kandung", location: ""},
            {name: "Arhan", role: "Mas/kakak sepupu", location: "(Bali)"},
            {name: "Agus", role: "Pakde", location: ""},
            {name: "Imah", role: "Mba/kakak sepupu", location: ""},
            {name: "Indra", role: "Pakde", location: ""},
            {name: "Inkutiatin", role: "Mbah", location: "(Kaltim)"},
            {name: "Imam", role: "Mas/kakak sepupu", location: "(Tanjung)"},
            {name: "Devi", role: "Mba/kakak sepupu", location: "(BJB)"},
            {name: "Dimas", role: "Mas/kakak sepupu", location: "(BJB)"},
            {name: "Deandra", role: "Mas/kakak sepupu", location: ""},
            {name: "Desy", role: "Bude", location: ""},
            {name: "Bila", role: "Mba/kakak sepupu", location: "(BJB)"},
            {name: "Bambang", role: "Mbah", location: "(Kaltim)"},
            {name: "Epan", role: "Mas/kakak sepupu", location: "(Jateng)"},
            {name: "Fauzi", role: "Pakde", location: "(Jatim)"},
            {name: "Ghani", role: "Mas/kakak sepupu", location: "(Tanjung)"},
            {name: "Guntur", role: "Mas/kakak sepupu", location: "(Yogyakarta)"},
            {name: "Kris", role: "Mbah", location: "(Tanjung)"},
            {name: "Marni", role: "Mbah", location: "(Jatim)"},
            {name: "Nanda", role: "Mba/kakak sepupu", location: "(Tanjung)"},
            {name: "Nabil", role: "Adek sepupu", location: "(Tanjung)"},
            {name: "Sanah", role: "Mba/kakak sepupu", location: "(Tanjung)"},
            {name: "Putri", role: "Mba/kakak sepupu", location: "(Tanjung)"},
            {name: "Willy", role: "Mas/kakak sepupu", location: ""},
            {name: "Ian", role: "Mas/kakak sepupu", location: "(sekampung)"},
            {name: "Iyan", role: "Mas/kakak sepupu", location: "(panggung)"},
            {name: "Haikal", role: "Mas/kakak sepupu", location: "(Kalbar)"},
            {name: "Yusuf", role: "Mas/kakak sepupu", location: "(Bali)"},
            {name: "Reza", role: "Mas/kakak sepupu", location: "(Jatim)"}
        ];

        // Generate family cards
        function generateFamilyCards() {
            const grid = document.getElementById('familyGrid');
            familyData.forEach(member => {
                const card = document.createElement('div');
                card.className = 'family-card';
                card.innerHTML = `
                    <div class="name">${member.name}</div>
                    <div class="role">${member.role}</div>
                    <div class="location">${member.location}</div>
                `;
                grid.appendChild(card);
            });
        }

        // Search functionality
        document.getElementById('searchInput').addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const cards = document.querySelectorAll('.family-card');
            
            cards.forEach(card => {
                const name = card.querySelector('.name').textContent.toLowerCase();
                const role = card.querySelector('.role').textContent.toLowerCase();
                
                if (name.includes(searchTerm) || role.includes(searchTerm)) {
                    card.classList.remove('hidden');
                } else {
                    card.classList.add('hidden');
                }
            });
        });

        // Chatbot functionality
        const chatMessages = document.getElementById('chatMessages');
        const chatInput = document.getElementById('chatInput');

        function addMessage(text, isUser = false) {
            const message = document.createElement('div');
            message.className = `message ${isUser ? 'user-message' : 'bot-message'}`;
            message.textContent = text;
            chatMessages.appendChild(message);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        function handleChat(event) {
            if (event.key === 'Enter') {
                const userMessage = chatInput.value.trim();
                if (userMessage) {
                    addMessage(userMessage, true);
                    chatInput.value = '';
                    
                    setTimeout(() => {
                        const botResponse = getBotResponse(userMessage.toLowerCase());
                        addMessage(botResponse);
                    }, 500);
                }
            }
        }

        function getBotResponse(message) {
            if (message.includes('halo') || message.includes('hai')) {
                return 'Halo! 👋 Selamat datang di Family Tree Marchella!';
            } else if (message.includes('marchella')) {
                return 'Marchella adalah teman spesial! ❤️ Dia pusat dari keluarga besar ini!';
            } else if (message.includes('haikal')) {
                return 'Haikal? Mas/kakak sepupu dari Kalbar! 😉 (Shhh... ada bonus khusus!)';
            } else if (message.includes('berapa') && message.includes('anggota')) {
                return `Ada ${familyData.length} anggota keluarga Marchella!`;
            } else if (message.includes('mbah') || message.includes('kakek') || message.includes('nenek')) {
                return 'Mbah-mbah yang hebat: Hari (Jatim), Yanti (Tanjung), Inkutiatin (Kaltim), Kris (Tanjung), Bambang (Kaltim), Marni (Jatim)';
            } else {
                return 'Keluarga Marchella besar sekali! Coba cari nama tertentu atau tanya "berapa anggota keluarga?" 😊';
            }
        }

        // Initialize
        generateFamilyCards();
    </script>
</body>
</html>
